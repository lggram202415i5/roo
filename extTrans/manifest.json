{
  "manifest_version": 3,
  "name": "Trans Data",
  "version": "1.0",
  "description": "Trans Data One to Another",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/utils.js", "src/content.js"]
    }
  ]
}